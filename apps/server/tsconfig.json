{
  "extends": "@mint/typescript-config/base",
  "compilerOptions": {
    "types": ["node"],
    "composite": true,
    "declarationMap": true,
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
